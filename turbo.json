{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:int": {
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "KAMINO_INTEGRATION",
        "MARGINFI_INTEGRATION",
        "LULO_INTEGRATION",
        "LULO_API_KEY",
        "SOLANA_RPC_URL"
      ]
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
